// N4ZL Theme by ziadlawatey
// github: ziadlawatey
// discord: ziadlawatey

// // Importing matugen colors
@import ".config/rofi/colors.rasi"

// // Some Configurations
configuration {
    show-icons: true;
}

// Global settings
* {
    font:   "SF Pro Display SemiBold 12";
    background-color:   transparent;
    text-color: #f2f2f2;
    padding:  0;
    margin: 0;
}

// Window
window {
    width:                       520px;
    background-color:   @surface;
    border-radius:  28px 28px 0 0;
    transparency:                "real";
    location:                    south;
}

// Main container
mainbox {
    padding:    15px;
    spacing:    15px;
    children:   [listbox, listview];
}

//  List box
listbox {
    children: [inputbar, icon-wipe];
    expand:     false;
    orientation:    horizontal;
    spacing:    10px;
}

// Input bar
inputbar {
    expand: true;
    children:   [ icon-search, entry ];
    background-color: @surface-container;
    spacing:    10px;
    padding:    0 15px 0 0;
    border-radius:  17px;
}

// Search icon
icon-search {
    expand:     false;
    filename:   "search-symbolic";
    size:   24px;
    background-color: @primary-container;
    padding:    8px 15px;
    border-radius:      17px;
}


icon-wipe {
    expand:     false;
    filename:   "edit-clear-all-symbolic";
    size:   24px;
    background-color: @primary-container;
    padding:    8px 15px;
    border-radius:      17px;
    action:         "kb-custom-1";
}

// Element cursor
icon-wipe, elemnent, element-icon, element-text {
    cursor:     pointer;
}

// Entry field
entry {
    cursor:         text;
    placeholder:    "Search";
    placeholder-color:  @outline;
    vertical-align:     0.5;
    color:  #ececec;
}

// Textbox
textbox {
    background-color:       @on-secondary-fixed;
    text-color:     @error;
    border-radius:  18px;
    padding:    20px;
}

// List view
listview {
    children:   [element, scrollbar];
    scrollbar:  true;
    fixed-height:   false;
    lines:  4;
    columns:    1;
    spacing:    7px;
    padding:    0 5px;
    cycle:  false;
}

// Scrollbar
scrollbar {
    handle-width:   5px;
    handle-rounded-corners: true;
    background-color:   @on-secondary;
    handle-color:   @on-surface-variant;
    margin: 0 7px 0 10px;
    border-radius:  5px;
}

// Element base
element {
background-color: @surface-container;
    padding: 0 10px;
    border-radius:  18px;
    spacing:    10px;
}

// Element selected normal
element selected normal {
    background-color:   @surface-bright;
}

// Element icon
element-icon {
    size:   3.5em;
}

// Element text
element-text {
    font:   "SF Pro Display SemiBold 12";
    vertical-align:   0.5;
}
