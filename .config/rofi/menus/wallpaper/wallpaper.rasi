@import ".config/rofi/colors.rasi"

configuration {
    show-icons: true;
    hover-select: true;
    me-select-entry: "";
    me-accept-entry: "MousePrimary";
}

window {
    font:   "Slat For OnePlus 12";
    width: 70%;
    border: 0;
    background-color: transparent;
    border-radius: 1.2em 1.2em 0 0;
    location: south;
}

mainbox {
    background-color:   @surface;
    border-color:   @border;
    padding: 1em 0.94em 1em 1em;
    spacing: 1em;
    children: [ "listview"];
    border-radius:  25px 25px 0 0;
}

// inputbar {
