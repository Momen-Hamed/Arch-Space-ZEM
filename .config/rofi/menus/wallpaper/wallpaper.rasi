// Search icon

listview {
    expand: false;
    columns: 7;
    lines: 1;
    spacing: 0.6em;
    padding: 0;
    flow: horizontal;
    fixed-height: true;
    fixed-columns: true;
    background-color: transparent;
    scrollbar: false;
    cycle:  false;
}

element {
    orientation: vertical;
    border-radius: 0.4em;
    background-color: transparent;
    cursor: pointer;
}

element selected.normal {
    // background-color: #ffffff18;
    border:     2px;
    border-color:   @primary;
}

element-icon {
    size: 12em;
    background-color: transparent;
    cursor: inherit;

}

element-text {
    enabled:    false;
}

element selected.normal element-text {
    text-color: #ffffff;
}
