{
  "layer": "top",
  "position": "top",
  "margin-top": 9,
  "margin-left": 11,
  "margin-right": 11,
  "height": 28,
  "spacing": 5,
  "modules-left": [
    "custom/launcher",
    "custom/media_player"
  ],
  "modules-center": [
    "clock",
    "hyprland/workspaces",
    "custom/weather"
  ],
  "modules-right": [
    "tray",
    "custom/keyboard",
    "group/system",
    "custom/power_options",
    "custom/notifications"
  ],
  "group/system": {
  "orientation": "horizontal",  // or "vertical"
  // "on-click": "swaync-client -t -sw",
  "modules": [
    "battery",
    "bluetooth",
    "network",
    "custom/volume"
  ]
},
"custom/power_options": {
    "format": "⏻",
    "exec": "~/.config/waybar/scripts/power_info.sh",
    "on-click": "~/.config/rofi/scripts/power_menu.sh",
    "return-type": "json",
    "tooltip": true,
    "interval": 60
},
"custom/keyboard": {
    "exec": "~/.config/waybar/scripts/kb_layout.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
},
"bluetooth": {
  "format": "󰂯",
  "format-disabled": "󰂲",
  "format-off": "󰂲",
  "format-connected-battery": "󰂱",
  "tooltip": true,
  "tooltip-format": "Bluetooth: {status}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} | {device_battery_percentage}%",
    "on-click": "overskride"
},
"custom/media_player": {
    "format": "{}",
    "return-type": "json",
    "max-length": 40,
    "interval": 2,
    "exec": "~/.config/waybar/scripts/media_player.sh",
    "on-click": "playerctl -p $(cat /tmp/waybar_media_player) play-pause",
    "on-click-right": "~/.config/waybar/scripts/media_player.sh switch",
    "on-click-middle": "~/.config/waybar/scripts/media_player.sh mute",
    "on-scroll-up": "~/.config/waybar/scripts/media_player.sh up",
    "on-scroll-down": "~/.config/waybar/scripts/media_player.sh down"
},
  "hyprland/workspaces": {
    "disable-scroll": true,
    "active-only": false,
    "all-outputs": true,
    "format": "{id}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
"tray": {
  "spacing": 9,
  "icon-size": 15,
  "reverse-direction": false,
},
"clock": {
    "format": "{:%I:%M %p} ",
    "on-click": "gnome-calendar",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "weeks-pos": "right", 
        "mode": "month",
        "on-scroll": 1,
        "format": {
            "months": "<span color='#ffead3'><b>{}</b></span>",
            "days": "<span color='#ecc6d9'>{}</span>",
            "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
            "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
            "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
        }
    },
    "actions": {
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down"
    }
},
  "network": {
    "format-wifi": "{icon}",
    "format-icons": [
      "󰤯",
      "󰤟",
      "󰤢",
      "󰤥",
      "󰤨"
    ],
    "format-ethernet": "󰀂",
    "format-disconnected": "󰖪",
    "tooltip-format-wifi": "{icon}  {essid}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
    "tooltip-format-ethernet": "󰀂  {ifname}\n⇣{bandwidthDownBytes}  ⇡{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nmgui",
    "interval": 5,
    "nospacing": 1
  },
  "custom/notifications": {
  "exec": "swaync-client -swb",
  "return-type": "json",
  "format": "{icon}",
  "format-icons": {
    "notification": "󰂚",  // Filled bell when there are notifications
    "none": "󰂜",          // Empty bell when no notifications
    "dnd-notification": "󰂛",  // Bell with slash when DND is on
    "dnd-none": "󰪑"
  },
  "tooltip": false,
  "on-click": "swaync-client -t -sw",
  "on-click-right": "swaync-client -d -sw"
},
"custom/volume": {
    "exec": "~/.config/waybar/scripts/volume_icon_fix.sh",
    "interval": 1,
    "format": "{}",
    "return-type": "json",
    "on-click": "pavucontrol",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
},
"battery": {
        "interval": 2,
        "states": {
            "warning": 25,
            "critical": 15
        },
        "format": "{icon}",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true,
        "tooltip-format": "{capacity}% | {timeTo}",
        "tooltip-format-charging": "+ {capacity}% | {timeTo}",
      },
  // "custom/waybar-media": {
  //   "format": "{player_icon} {artist} - {title}",
  //   "max-length": 40,
  //   "on-click": "playerctl play-pause",
  //   "on-scroll-up": "playerctl next",
  //   "on-scroll-down": "playeryctl previous"
  // }
"custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "interval": 1800,
    "on-click": "gnome-weather",
    "return-type": "json",
    "format": "{}",
    "tooltip": true
},
"custom/launcher": {
    "format": "󰀻",
    "on-click": "~/.config/rofi/scripts/launch_options.sh launcher",
    "tooltip": true,
    "tooltip-format": "Launcher"
}
}
